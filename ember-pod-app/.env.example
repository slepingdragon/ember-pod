# Copy this file to `.env` and paste real values. `.env` is gitignored.
#
# IMPORTANT: anything prefixed with EXPO_PUBLIC_ gets inlined into the
# JavaScript bundle and is therefore visible to anyone who decompiles the
# APK. That's acceptable for the dev/preview build but for production we
# should proxy these calls through api.ember-pod.com (FastAPI on Railway)
# and keep the keys server-side.

# RapidAPI key for the Google Trends Keywords API
# (https://rapidapi.com/baniabradyy/api/google-trends-keywords)
EXPO_PUBLIC_RAPIDAPI_KEY=

# RapidAPI host header — usually does not change
EXPO_PUBLIC_RAPIDAPI_HOST=google-trends-keywords.p.rapidapi.com
